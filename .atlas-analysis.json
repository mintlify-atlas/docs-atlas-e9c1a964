{
  "projectType": "cli-tool",
  "projectName": "CS2 SDK",
  "projectDescription": "A single-binary external dumper for Counter-Strike 2 that extracts offsets, schemas, interfaces, buttons, and signatures from a live CS2 process and emits them in C++, C#, Rust, and Zig.",
  "theme": "aspen",
  "primaryColor": "#fa9e22",
